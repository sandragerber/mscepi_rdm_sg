# 2021
# implement Reed-frost model
# authors: Melissa Penny, James Munday
# date: 20.04.2021 (modified 13.04.2026)
###################################################
# single investigation of Reed Frost
library("scales")
# - parameter values
N = 500 #total
p = 0.008 # probablity infectious contact results in an infection
# Simulation times
timeSim = 10
#preassign vectors of our variables
Suscept = array(NA, dim=c(timeSim))
Infect = array(NA, dim=c(timeSim))
Recovered = array(NA, dim=c(timeSim))
# Initial conditions
Suscept[1] = N-1
Infect[1] = 1
Recovered[1] =0
# equations
for( t in 1:(timeSim-1)){
Suscept[t+1] = rbinom(1, Suscept[t], (1-p)^Infect[t])
Infect[t+1] = Suscept[t] - Suscept[t+1]
Recovered[t+1] = Recovered[t]+Infect[t]
}
# plot results
timeVec = seq(1:timeSim)
plot( timeVec, Suscept, type ="l", xlab="time", ylab="S/I/R", lwd=3, main = "Reed Frost example")
lines(timeVec, Infect, col="red", lwd=3)
lines(timeVec, Recovered, col="blue", lwd=3)
#############################
# stochastic investigation of Reed Frost
timeSim = 10
numSim = 200
#preassign vectors of our variables
Suscept = array(NA, dim=c(numSim, timeSim))
Infect = array(NA, dim=c(numSim, timeSim))
Recovered = array(NA, dim=c(numSim, timeSim))
N = 500#total
p = 4/N
# loop over the number simulations
for(n in 1:numSim){
#inital conditions
Suscept[n,1] = N-ceiling(N/100)
Infect[n,1] = ceiling(N/100)
Recovered[n,1] = 0
#loop over time
for( t in 1:(timeSim-1)){
Suscept[n,t+1] = rbinom(1, Suscept[n,t], (1-p)^Infect[n,t])
Infect[n,t+1] = Suscept[n,t]-Suscept[n,t+1]
Recovered[n,t+1] = Recovered[n,t]+Infect[n,t]
}
}
# plot
timeVec = seq(1: timeSim)
plot( timeVec , Suscept[1,], type = "l", xlab = "time", ylab = "S", lwd =3, main = "Reed Frost results" , ylim = c(0,N))
for (n in 2:numSim){
lines(timeVec, Suscept[n,],lwd =3, col=alpha('black',0.1))
}
for (n in 1:numSim){
lines(timeVec, Infect[n,],col = alpha("red",0.1),lwd =3)
}
# for (n in 1:numSim){
# lines(timeVec, Recovered[n,],col = "blue",lwd =3)
# }
